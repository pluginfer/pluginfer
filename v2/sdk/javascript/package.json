{
  "name": "@pluginfer/sdk",
  "version": "1.0.0",
  "description": "JavaScript / TypeScript SDK for Pluginfer \u2014 distributed AI compute mesh.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist-cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    }
  },
  "files": [
    "dist",
    "dist-cjs",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist-cjs/package.json','{\\\"type\\\":\\\"commonjs\\\"}')\"",
    "test": "node --test test/client.test.mjs"
  },
  "keywords": [
    "pluginfer",
    "distributed",
    "gpu",
    "ai",
    "inference",
    "compute"
  ],
  "author": "Pluginfer Team <ops@pluginfer.network>",
  "homepage": "https://pluginfer.network",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pluginfer/pluginfer.git"
  },
  "bugs": {
    "url": "https://github.com/pluginfer/pluginfer/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  }
}
